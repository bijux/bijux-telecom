{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RtkBaselineQuality",
  "type": "object",
  "required": [
    "epoch_idx",
    "fixed",
    "sigma_e",
    "sigma_n",
    "sigma_u",
    "used_sats",
    "residual_rms_m",
    "predicted_rms_m"
  ],
  "properties": {
    "epoch_idx": { "type": "integer", "minimum": 0 },
    "fixed": { "type": "boolean" },
    "sigma_e": { "type": "number" },
    "sigma_n": { "type": "number" },
    "sigma_u": { "type": "number" },
    "used_sats": { "type": "integer", "minimum": 0 },
    "residual_rms_m": { "type": "number" },
    "predicted_rms_m": { "type": "number" }
  }
}

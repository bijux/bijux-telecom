{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RtkPrecisionV1",
  "type": "object",
  "required": ["header", "payload"],
  "properties": {
    "header": { "$ref": "#/definitions/ArtifactHeader" },
    "payload": { "$ref": "#/definitions/RtkPrecision" }
  },
  "definitions": {
    "ArtifactHeader": {
      "type": "object",
      "required": [
        "schema_version",
        "producer",
        "producer_version",
        "created_at_unix_ms",
        "git_sha",
        "config_hash",
        "toolchain",
        "features",
        "deterministic",
        "git_dirty"
      ],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "producer": { "type": "string" },
        "producer_version": { "type": "string" },
        "created_at_unix_ms": { "type": "integer", "minimum": 0 },
        "git_sha": { "type": "string" },
        "config_hash": { "type": "string" },
        "dataset_id": { "type": ["string", "null"] },
        "toolchain": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "deterministic": { "type": "boolean" },
        "git_dirty": { "type": "boolean" }
      }
    },
    "RtkPrecision": {
      "type": "object",
      "required": [
        "epoch_idx",
        "fix_accepted",
        "ratio",
        "fixed_count",
        "ref_changed",
        "slip_count"
      ],
      "properties": {
        "epoch_idx": { "type": "integer", "minimum": 0 },
        "fix_accepted": { "type": "boolean" },
        "ratio": { "type": ["number", "null"] },
        "fixed_count": { "type": "integer", "minimum": 0 },
        "ref_changed": { "type": "boolean" },
        "slip_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}

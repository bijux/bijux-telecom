{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RtkBaselineQualityV1",
  "type": "object",
  "required": ["header", "payload"],
  "properties": {
    "header": { "$ref": "#/definitions/ArtifactHeader" },
    "payload": { "$ref": "#/definitions/RtkBaselineQuality" }
  },
  "definitions": {
    "ArtifactHeader": {
      "type": "object",
      "required": [
        "schema_version",
        "producer",
        "producer_version",
        "created_at_unix_ms",
        "git_sha",
        "config_hash",
        "toolchain",
        "features",
        "deterministic",
        "git_dirty"
      ],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "producer": { "type": "string" },
        "producer_version": { "type": "string" },
        "created_at_unix_ms": { "type": "integer", "minimum": 0 },
        "git_sha": { "type": "string" },
        "config_hash": { "type": "string" },
        "dataset_id": { "type": ["string", "null"] },
        "toolchain": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "deterministic": { "type": "boolean" },
        "git_dirty": { "type": "boolean" }
      }
    },
    "RtkBaselineQuality": {
      "type": "object",
      "required": ["epoch_idx", "status", "value"],
      "properties": {
        "epoch_idx": { "type": "integer", "minimum": 0 },
        "status": {
          "type": "string",
          "enum": ["executed", "not_ready", "unsupported"]
        },
        "reason": { "type": ["string", "null"] },
        "value": {
          "anyOf": [
            { "$ref": "#/definitions/BaselineQuality" },
            { "type": "null" }
          ]
        }
      }
    },
    "BaselineQuality": {
      "type": "object",
      "required": [
        "epoch_idx",
        "fixed",
        "sigma_e",
        "sigma_n",
        "sigma_u",
        "used_sats",
        "residual_rms_m",
        "predicted_rms_m",
        "hpl_m",
        "vpl_m"
      ],
      "properties": {
        "epoch_idx": { "type": "integer", "minimum": 0 },
        "fixed": { "type": "boolean" },
        "sigma_e": { "type": "number" },
        "sigma_n": { "type": "number" },
        "sigma_u": { "type": "number" },
        "used_sats": { "type": "integer", "minimum": 0 },
        "residual_rms_m": { "type": "number" },
        "predicted_rms_m": { "type": "number" },
        "hpl_m": { "type": "number" },
        "vpl_m": { "type": "number" },
        "separation_sig": { "type": "string" },
        "separation_max_m": { "type": "number" }
      }
    }
  }
}

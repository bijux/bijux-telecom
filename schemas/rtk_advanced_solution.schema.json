{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RtkAdvancedSolution",
  "type": "object",
  "required": [
    "epoch_idx",
    "mode",
    "status",
    "downgraded",
    "prerequisites",
    "provenance",
    "artifact_id",
    "source_observation_epoch_id"
  ],
  "properties": {
    "epoch_idx": { "type": "integer", "minimum": 0 },
    "mode": { "type": "string", "enum": ["Rtk", "Ppp"] },
    "status": { "type": "string" },
    "downgraded": { "type": "boolean" },
    "downgrade_reason": { "type": ["string", "null"] },
    "prerequisites": { "type": "object" },
    "refusal_class": {
      "type": ["string", "null"],
      "enum": [
        "IncompleteCorrections",
        "MissingBaseline",
        "UnsupportedModel",
        "InsufficientGeometry",
        "IncompleteAmbiguityState",
        null
      ]
    },
    "provenance": { "type": "object" },
    "artifact_id": { "type": "string" },
    "source_observation_epoch_id": { "type": "string" }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RtkSingleDifference",
  "type": "object",
  "required": [
    "sig",
    "rover_pseudorange_m",
    "rover_signal_timing",
    "base_pseudorange_m",
    "base_signal_timing",
    "code_m",
    "phase_cycles",
    "doppler_hz",
    "variance_code",
    "variance_phase",
    "ambiguity_rover",
    "ambiguity_base"
  ],
  "properties": {
    "sig": { "type": "object" },
    "rover_pseudorange_m": { "type": "number" },
    "rover_signal_timing": { "type": ["object", "null"] },
    "base_pseudorange_m": { "type": "number" },
    "base_signal_timing": { "type": ["object", "null"] },
    "code_m": { "type": "number" },
    "phase_cycles": { "type": "number" },
    "doppler_hz": { "type": "number" },
    "variance_code": { "type": "number", "minimum": 0.0 },
    "variance_phase": { "type": "number", "minimum": 0.0 },
    "ambiguity_rover": { "type": "object" },
    "ambiguity_base": { "type": "object" }
  }
}

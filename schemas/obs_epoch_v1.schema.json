{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ObsEpochV1",
  "type": "object",
  "required": ["header", "payload"],
  "properties": {
    "header": { "$ref": "#/definitions/ArtifactHeader" },
    "payload": { "$ref": "#/definitions/ObsEpoch" }
  },
  "definitions": {
    "ArtifactHeader": {
      "type": "object",
      "required": [
        "schema_version",
        "producer",
        "producer_version",
        "created_at_unix_ms",
        "git_sha",
        "config_hash",
        "toolchain",
        "features",
        "deterministic",
        "git_dirty"
      ],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "producer": { "type": "string" },
        "producer_version": { "type": "string" },
        "created_at_unix_ms": { "type": "integer", "minimum": 0 },
        "git_sha": { "type": "string" },
        "config_hash": { "type": "string" },
        "dataset_id": { "type": ["string", "null"] },
        "toolchain": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "deterministic": { "type": "boolean" },
        "git_dirty": { "type": "boolean" }
      }
    },
    "ReceiverSampleTrace": {
      "type": "object",
      "required": ["sample_index", "sample_rate_hz", "receiver_time_s"],
      "properties": {
        "sample_index": { "type": "integer", "minimum": 0 },
        "sample_rate_hz": { "type": "number", "exclusiveMinimum": 0 },
        "receiver_time_s": { "type": "number" }
      }
    },
    "GpsTime": {
      "type": "object",
      "required": ["week", "tow_s"],
      "properties": {
        "week": { "type": "integer", "minimum": 0 },
        "tow_s": { "type": "number", "minimum": 0 }
      }
    },
    "SatId": {
      "type": "object",
      "required": ["constellation", "prn"],
      "properties": {
        "constellation": { "type": "string" },
        "prn": { "type": "integer", "minimum": 1 }
      }
    },
    "SigId": {
      "type": "object",
      "required": ["sat", "band", "code"],
      "properties": {
        "sat": { "$ref": "#/definitions/SatId" },
        "band": { "type": "string" },
        "code": { "type": "string" }
      }
    },
    "SignalSpec": {
      "type": "object",
      "required": ["constellation", "band", "code", "code_rate_hz", "carrier_hz"],
      "properties": {
        "constellation": { "type": "string" },
        "band": { "type": "string" },
        "code": { "type": "string" },
        "code_rate_hz": { "type": "number" },
        "carrier_hz": { "type": "number" }
      }
    },
    "TrackingUncertainty": {
      "type": "object",
      "required": [
        "code_phase_samples",
        "carrier_phase_cycles",
        "doppler_hz",
        "cn0_dbhz"
      ],
      "properties": {
        "code_phase_samples": { "type": "number", "minimum": 0 },
        "carrier_phase_cycles": { "type": "number", "minimum": 0 },
        "doppler_hz": { "type": "number", "minimum": 0 },
        "cn0_dbhz": { "type": "number", "minimum": 0 }
      }
    },
    "CodeCarrierDivergence": {
      "type": "object",
      "required": [
        "raw_m",
        "jump_m",
        "expected_ionosphere_m",
        "receiver_clock_m",
        "oscillator_m",
        "smoothing_transient_m",
        "multipath_m",
        "unexplained_m"
      ],
      "properties": {
        "raw_m": { "type": "number" },
        "jump_m": { "type": "number" },
        "expected_ionosphere_m": { "type": "number" },
        "receiver_clock_m": { "type": "number" },
        "oscillator_m": { "type": "number" },
        "smoothing_transient_m": { "type": "number" },
        "multipath_m": { "type": "number" },
        "unexplained_m": { "type": "number" }
      }
    },
    "ObsMetadata": {
      "type": "object",
      "required": [
        "tracking_mode",
        "integration_ms",
        "lock_quality",
        "smoothing_window",
        "smoothing_age",
        "smoothing_resets",
        "signal",
        "time_tag_sample_index",
        "time_tag_sample_rate_hz"
      ],
      "properties": {
        "tracking_mode": { "type": "string" },
        "integration_ms": { "type": "integer", "minimum": 0 },
        "lock_quality": { "type": "number" },
        "smoothing_window": { "type": "integer", "minimum": 0 },
        "smoothing_age": { "type": "integer", "minimum": 0 },
        "smoothing_resets": { "type": "integer", "minimum": 0 },
        "signal": { "$ref": "#/definitions/SignalSpec" },
        "time_tag_sample_index": { "type": "integer", "minimum": 0 },
        "time_tag_sample_rate_hz": { "type": "number", "exclusiveMinimum": 0 },
        "tracking_uncertainty": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/definitions/TrackingUncertainty" }
          ]
        },
        "code_carrier_divergence": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/definitions/CodeCarrierDivergence" }
          ]
        },
        "cycle_slip_evidence": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/definitions/CycleSlipDecisionEvidence" }
          ]
        }
      }
    },
    "LockFlags": {
      "type": "object",
      "required": ["code_lock", "carrier_lock", "bit_lock", "cycle_slip"],
      "properties": {
        "code_lock": { "type": "boolean" },
        "carrier_lock": { "type": "boolean" },
        "bit_lock": { "type": "boolean" },
        "cycle_slip": { "type": "boolean" }
      }
    },
    "CycleSlipDetectorEvidence": {
      "type": "object",
      "required": ["detector", "triggered", "value", "threshold", "units", "reason"],
      "properties": {
        "detector": {
          "type": "string",
          "enum": [
            "tracking_lock",
            "doppler_predicted_phase",
            "geometry_free_phase",
            "melbourne_wubbena",
            "data_gap",
            "phase_innovation",
            "code_carrier_divergence"
          ]
        },
        "triggered": { "type": "boolean" },
        "value": { "type": ["number", "null"] },
        "threshold": { "type": ["number", "null"] },
        "units": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "CycleSlipDecisionEvidence": {
      "type": "object",
      "required": [
        "detected",
        "primary_reason",
        "contributors",
        "detection_probability_budget",
        "false_alarm_probability_budget"
      ],
      "properties": {
        "detected": { "type": "boolean" },
        "primary_reason": { "type": ["string", "null"] },
        "contributors": {
          "type": "array",
          "items": { "$ref": "#/definitions/CycleSlipDetectorEvidence" }
        },
        "detection_probability_budget": { "type": "number", "minimum": 0, "maximum": 1 },
        "false_alarm_probability_budget": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "ObsSignalTiming": {
      "type": "object",
      "required": ["signal_travel_time_s", "transmit_gps_time"],
      "properties": {
        "signal_travel_time_s": { "type": "number", "exclusiveMinimum": 0 },
        "transmit_gps_time": { "$ref": "#/definitions/GpsTime" }
      }
    },
    "ObsSatellite": {
      "type": "object",
      "required": [
        "signal_id",
        "pseudorange_m",
        "pseudorange_var_m2",
        "carrier_phase_cycles",
        "carrier_phase_var_cycles2",
        "doppler_hz",
        "doppler_var_hz2",
        "cn0_dbhz",
        "lock_flags",
        "multipath_suspect",
        "metadata"
      ],
      "properties": {
        "signal_id": { "$ref": "#/definitions/SigId" },
        "pseudorange_m": { "type": "number" },
        "pseudorange_var_m2": { "type": "number" },
        "carrier_phase_cycles": { "type": "number" },
        "carrier_phase_var_cycles2": { "type": "number" },
        "doppler_hz": { "type": "number" },
        "doppler_var_hz2": { "type": "number" },
        "cn0_dbhz": { "type": "number" },
        "lock_flags": { "$ref": "#/definitions/LockFlags" },
        "multipath_suspect": { "type": "boolean" },
        "timing": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/definitions/ObsSignalTiming" }
          ]
        },
        "metadata": { "$ref": "#/definitions/ObsMetadata" }
      }
    },
    "ObsEpochManifest": {
      "type": "object",
      "required": [
        "version",
        "artifact_id",
        "epoch_id",
        "source_epoch_idx",
        "source_sample_index",
        "source_time",
        "decision",
        "downstream_profile_version"
      ],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "artifact_id": { "type": "string", "minLength": 1 },
        "epoch_id": { "type": "string", "minLength": 1 },
        "source_epoch_idx": { "type": "integer", "minimum": 0 },
        "source_sample_index": { "type": "integer", "minimum": 0 },
        "source_time": { "$ref": "#/definitions/ReceiverSampleTrace" },
        "decision": { "type": "string" },
        "downstream_profile_version": { "type": "integer", "minimum": 1 }
      }
    },
    "ObsEpoch": {
      "type": "object",
      "required": [
        "t_rx_s",
        "source_time",
        "epoch_idx",
        "discontinuity",
        "role",
        "sats",
        "decision",
        "manifest"
      ],
      "properties": {
        "t_rx_s": { "type": "number" },
        "source_time": { "$ref": "#/definitions/ReceiverSampleTrace" },
        "gps_week": { "type": ["integer", "null"], "minimum": 0 },
        "tow_s": { "type": ["number", "null"] },
        "epoch_idx": { "type": "integer", "minimum": 0 },
        "discontinuity": { "type": "boolean" },
        "valid": { "type": "boolean" },
        "role": { "type": "string" },
        "sats": {
          "type": "array",
          "items": { "$ref": "#/definitions/ObsSatellite" }
        },
        "decision": { "type": "string" },
        "manifest": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/definitions/ObsEpochManifest" }
          ]
        }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReceiverProfile",
  "type": "object",
  "properties": {
    "sample_rate_hz": {
      "type": "number"
    },
    "intermediate_freq_hz": {
      "type": "number"
    },
    "quantization_bits": {
      "type": "integer"
    },
    "code_freq_basis_hz": {
      "type": "number"
    },
    "code_length": {
      "type": "integer"
    },
    "seed": {
      "type": "integer"
    },
    "acquisition": {
      "type": "object",
      "properties": {
        "doppler_search_hz": {
          "type": "integer"
        },
        "doppler_step_hz": {
          "type": "integer"
        },
        "integration_ms": {
          "type": "integer"
        },
        "peak_mean_threshold": {
          "type": "number"
        },
        "peak_second_threshold": {
          "type": "number"
        }
      }
    },
    "tracking": {
      "type": "object",
      "properties": {
        "early_late_spacing_chips": {
          "type": "number"
        },
        "dll_bw_hz": {
          "type": "number"
        },
        "pll_bw_hz": {
          "type": "number"
        },
        "fll_bw_hz": {
          "type": "number"
        },
        "max_channels": {
          "type": "integer"
        },
        "per_epoch_budget_ms": {
          "type": "number"
        },
        "integration_ms": {
          "type": "integer"
        },
        "per_band": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "band": { "type": "string" },
              "early_late_spacing_chips": { "type": "number" },
              "dll_bw_hz": { "type": "number" },
              "pll_bw_hz": { "type": "number" },
              "fll_bw_hz": { "type": "number" },
              "integration_ms": { "type": "integer" }
            }
          }
        }
      }
    },
    "navigation": {
      "type": "object",
      "properties": {
        "robust_solver": {
          "type": "boolean"
        },
        "huber_k": {
          "type": "number"
        },
        "raim": {
          "type": "boolean"
        },
        "hatch_window": {
          "type": "integer"
        },
        "iono_mode": {
          "type": "string"
        },
        "tropo_enable": {
          "type": "boolean"
        },
        "tropo_ztd_m": {
          "type": "number"
        },
        "ppp": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "use_iono_free": { "type": "boolean" },
            "use_doppler": { "type": "boolean" },
            "enable_iono_state": { "type": "boolean" },
            "ar_mode": { "type": "string" },
            "ar_ratio_threshold": { "type": "number" },
            "ar_stability_epochs": { "type": "integer" },
            "ar_max_sats": { "type": "integer" },
            "ar_use_elevation": { "type": "boolean" },
            "prune_after_epochs": { "type": "integer" },
            "reset_gap_s": { "type": "number" },
            "residual_gate_m": { "type": "number" },
            "drift_window_epochs": { "type": "integer" },
            "drift_threshold_m": { "type": "number" },
            "checkpoint_interval_epochs": { "type": "integer" },
            "noise_clock_drift": { "type": "number" },
            "noise_ztd": { "type": "number" },
            "noise_iono": { "type": "number" },
            "noise_ambiguity": { "type": "number" },
            "convergence_min_time_s": { "type": "number" },
            "convergence_pos_rate_mps": { "type": "number" },
            "convergence_sigma_h_m": { "type": "number" },
            "convergence_sigma_v_m": { "type": "number" }
          }
        },
        "weighting": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "min_elev_deg": {
              "type": "number"
            },
            "elev_exponent": {
              "type": "number"
            },
            "cn0_ref_dbhz": {
              "type": "number"
            },
            "min_weight": {
              "type": "number"
            },
            "elev_mask_deg": {
              "type": "number"
            },
            "tracking_mode_scalar_weight": {
              "type": "number"
            },
            "tracking_mode_vector_weight": {
              "type": "number"
            }
          }
        }
      }
    }
  }
}

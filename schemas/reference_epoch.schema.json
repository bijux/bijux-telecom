{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReferenceEpoch",
  "type": "object",
  "required": ["epoch_idx", "latitude_deg", "longitude_deg", "altitude_m"],
  "properties": {
    "epoch_idx": { "type": "integer", "minimum": 0 },
    "t_rx_s": { "type": ["number", "null"] },
    "latitude_deg": { "type": "number" },
    "longitude_deg": { "type": "number" },
    "altitude_m": { "type": "number" },
    "ecef_x_m": { "type": ["number", "null"] },
    "ecef_y_m": { "type": ["number", "null"] },
    "ecef_z_m": { "type": ["number", "null"] },
    "vel_x_mps": { "type": ["number", "null"] },
    "vel_y_mps": { "type": ["number", "null"] },
    "vel_z_mps": { "type": ["number", "null"] }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RtkBaseline",
  "type": "object",
  "required": ["enu_m", "fixed"],
  "properties": {
    "enu_m": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "number" }
    },
    "covariance_m2": {
      "type": ["array", "null"],
      "minItems": 3,
      "maxItems": 3
    },
    "fixed": { "type": "boolean" }
  }
}

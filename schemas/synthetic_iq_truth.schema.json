{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SyntheticIqTruthBundle",
  "type": "object",
  "required": [
    "schema_version",
    "scenario_id",
    "seed",
    "sample_format",
    "sample_rate_hz",
    "intermediate_freq_hz",
    "capture_start_utc",
    "quantization_bits",
    "duration_s",
    "sample_count",
    "noise_std_per_component",
    "noise_power_per_complex_sample",
    "peak_component_before_scaling",
    "output_scale_applied",
    "satellites"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 2 },
    "scenario_id": { "type": "string", "minLength": 1 },
    "seed": { "type": "integer", "minimum": 0 },
    "sample_format": { "type": "string", "enum": ["iq16_le", "iq8", "cf32_le"] },
    "sample_rate_hz": { "type": "number", "exclusiveMinimum": 0 },
    "intermediate_freq_hz": { "type": "number" },
    "capture_start_utc": { "type": "string", "minLength": 1 },
    "quantization_bits": { "type": "integer", "minimum": 1 },
    "duration_s": { "type": "number", "minimum": 0 },
    "sample_count": { "type": "integer", "minimum": 0 },
    "noise_std_per_component": { "type": "number", "exclusiveMinimum": 0 },
    "noise_power_per_complex_sample": { "type": "number", "exclusiveMinimum": 0 },
    "peak_component_before_scaling": { "type": "number", "minimum": 0 },
    "output_scale_applied": { "type": "number", "exclusiveMinimum": 0 },
    "satellites": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "sat",
          "doppler_hz",
          "code_phase_chips",
          "carrier_phase_rad",
          "cn0_db_hz",
          "signal_amplitude",
          "nav_bit_mode",
          "nav_bit_segments"
        ],
        "properties": {
          "sat": {
            "type": "object",
            "required": ["constellation", "prn"],
            "properties": {
              "constellation": { "type": "string" },
              "prn": { "type": "integer", "minimum": 1 }
            }
          },
          "doppler_hz": { "type": "number" },
          "code_phase_chips": { "type": "number" },
          "carrier_phase_rad": { "type": "number" },
          "cn0_db_hz": { "type": "number" },
          "signal_amplitude": { "type": "number", "exclusiveMinimum": 0 },
          "nav_bit_mode": {
            "type": "string",
            "enum": ["constant_positive", "alternating_gps_lnav20ms"]
          },
          "nav_bit_segments": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["start_sample", "end_sample", "start_s", "end_s", "bit"],
              "properties": {
                "start_sample": { "type": "integer", "minimum": 0 },
                "end_sample": { "type": "integer", "minimum": 0 },
                "start_s": { "type": "number", "minimum": 0 },
                "end_s": { "type": "number", "minimum": 0 },
                "bit": { "type": "integer", "enum": [-1, 1] }
              }
            }
          }
        }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DiagnosticsOperatorMapReport",
  "type": "object",
  "required": ["schema_version", "operator_map"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "operator_map": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["workflow", "goal", "command"],
        "properties": {
          "workflow": { "type": "string" },
          "goal": { "type": "string" },
          "command": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

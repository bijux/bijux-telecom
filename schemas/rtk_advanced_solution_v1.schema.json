{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RtkAdvancedSolutionV1",
  "type": "object",
  "required": ["header", "payload"],
  "properties": {
    "header": { "$ref": "#/definitions/ArtifactHeader" },
    "payload": { "$ref": "#/definitions/RtkAdvancedSolution" }
  },
  "definitions": {
    "ArtifactHeader": {
      "type": "object",
      "required": [
        "schema_version",
        "producer",
        "producer_version",
        "created_at_unix_ms",
        "git_sha",
        "config_hash",
        "toolchain",
        "features",
        "deterministic",
        "git_dirty"
      ],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "producer": { "type": "string" },
        "producer_version": { "type": "string" },
        "created_at_unix_ms": { "type": "integer", "minimum": 0 },
        "git_sha": { "type": "string" },
        "config_hash": { "type": "string" },
        "dataset_id": { "type": ["string", "null"] },
        "toolchain": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "deterministic": { "type": "boolean" },
        "git_dirty": { "type": "boolean" }
      }
    },
    "RtkAdvancedSolution": {
      "type": "object",
      "required": [
        "epoch_idx",
        "mode",
        "status",
        "downgraded",
        "prerequisites",
        "provenance",
        "artifact_id",
        "source_observation_epoch_id"
      ],
      "properties": {
        "epoch_idx": { "type": "integer", "minimum": 0 },
        "mode": { "type": "string", "enum": ["Rtk", "Ppp"] },
        "status": { "type": "string" },
        "downgraded": { "type": "boolean" },
        "downgrade_reason": { "type": ["string", "null"] },
        "prerequisites": { "type": "object" },
        "refusal_class": {
          "type": ["string", "null"],
          "enum": [
            "IncompleteCorrections",
            "MissingBaseline",
            "UnsupportedModel",
            "InsufficientGeometry",
            "IncompleteAmbiguityState",
            null
          ]
        },
        "provenance": { "type": "object" },
        "artifact_id": { "type": "string" },
        "source_observation_epoch_id": { "type": "string" }
      }
    }
  }
}

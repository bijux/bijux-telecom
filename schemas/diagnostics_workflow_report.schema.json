{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DiagnosticsWorkflowReport",
  "type": "object",
  "required": ["schema_version", "workflow"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "workflow": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "command", "artifacts"],
        "properties": {
          "stage": { "type": "string" },
          "command": { "type": "string" },
          "artifacts": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
